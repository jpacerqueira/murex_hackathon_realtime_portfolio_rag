# --- MCP HTTP bridge ---------------------------------------------------------
# Base URL of mcp_http_server.py (the FastAPI bridge).
#
#   * Inside the docker-compose network: http://mcp-server:7001
#   * From your laptop with the stack up: http://localhost:7001
#   * Standalone bridge on a custom port: http://localhost:8080
MCP_BRIDGE_URL=http://mcp-server:7001

# Optional: HTTP timeout (seconds) for calls to the bridge.
MCP_BRIDGE_TIMEOUT=30

# Optional: bearer token if your bridge sits behind an auth proxy.
# MCP_BRIDGE_TOKEN=

# --- Gemini / ADK ------------------------------------------------------------
# One of these two must be set.
GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# Model used by the agent. Override to use a different Gemini model.
ADK_MODEL=gemini-3.1-pro-preview

# --- HITL --------------------------------------------------------------------
# Path to the YAML file that classifies MCP tools as read_only or mutating.
TOOL_CLASSIFICATION_PATH=assets/tool_classification.yaml

# If true, any MCP tool not matched by the classification rules is treated as
# mutating (fail closed). If false, unknown tools are treated as read-only.
HITL_FAIL_CLOSED=true
